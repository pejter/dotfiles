# Disable beep
unsetopt beep

# Auto-pushd (cd pushes to directory stack)
setopt auto_pushd
setopt pushd_ignore_dups
setopt pushd_minus

# Zephyr plugin config (must be set before sourcing plugins)
zstyle ':zephyr:plugin:editor' key-bindings emacs
# zstyle ':zephyr:plugin:editor:emacs' cursor block
zstyle ':zephyr:plugin:completion' use-cache yes
zstyle ':zephyr:plugin:homebrew' keg-only-brews curl libpq sqlite
HOMEBREW_NO_ANALYTICS=0
setopt share_history

# Docker completion stacking
zstyle ':completion:*:*:docker:*' option-stacking yes
zstyle ':completion:*:*:docker-*:*' option-stacking yes

# Antidote static plugins
source ~/.zsh_plugins.zsh

# Prefix-based history search with Up/Down
bindkey "$key_info[Up]" history-beginning-search-backward
bindkey "$key_info[Down]" history-beginning-search-forward

# Keychain
if command -v keychain >/dev/null 2>&1; then
	eval $(keychain --eval --quiet --agents ssh,gpg)
fi

# Git helper functions
function git_current_branch() {
	git rev-parse --abbrev-ref HEAD 2>/dev/null
}

function git_main_branch() {
	local branch
	for branch in main trunk master; do
		if git show-ref -q --verify "refs/heads/$branch" 2>/dev/null; then
			echo $branch
			return
		fi
	done
	echo main
}

if command -v mise >/dev/null 2>&1; then
	eval "$(mise activate zsh)"
fi

if command -v av >/dev/null 2>&1; then
	source =(av completion zsh)
	alias avs="av sync"
	alias avs!="av sync --rebase-to-trunk --ff-trunk"
	alias avsw="av switch"
fi

if [ -f /usr/share/nnn/quitcd/quitcd.bash_sh_zsh ]; then
	source /usr/share/nnn/quitcd/quitcd.bash_sh_zsh
elif [ -f "${HOMEBREW_PREFIX:-/opt/homebrew}/share/nnn/quitcd/quitcd.bash_sh_zsh" ]; then
	source "${HOMEBREW_PREFIX:-/opt/homebrew}/share/nnn/quitcd/quitcd.bash_sh_zsh"
fi

if [ -f /usr/share/autojump/autojump.zsh ]; then
	source /usr/share/autojump/autojump.zsh
elif [ -f "${HOMEBREW_PREFIX:-/opt/homebrew}/share/autojump/autojump.zsh" ]; then
	source "${HOMEBREW_PREFIX:-/opt/homebrew}/share/autojump/autojump.zsh"
fi

# Starship prompt
eval "$(starship init zsh)"

# Git aliases
alias gc='git commit -v'
alias gc!='git commit -v --amend'
alias gcb='git checkout -b'
alias gcm='git checkout $(git_main_branch)'
alias gp='git push'
alias gpf='git push --force-with-lease'
alias gpsup='git push --set-upstream origin $(git_current_branch)'
alias grbi='git rebase -i'
alias gst='git status'
alias gsta='git stash push'
alias gstp='git stash pop'
alias gb='git branch'

# General aliases
alias l="ls -lah"
alias dirs="dirs -v"
alias wrk='docker run --rm --net=host williamyeh/wrk'
alias dive='docker run --rm -it -v /var/run/docker.sock:/var/run/docker.sock wagoodman/dive:latest'
alias docker-here='docker run --rm -it -v $PWD:$PWD --workdir $PWD'
alias docker-aws='docker run --rm -it -v ~/.aws:/root/.aws -e AWS_PROFILE'
alias diffoscope='docker-here registry.salsa.debian.org/reproducible-builds/diffoscope'
alias aws-cli='docker run --rm -it -v ~/.aws:/root/.aws -v $PWD:/aws amazon/aws-cli'
alias dc='docker-compose'
alias tf='terraform'
